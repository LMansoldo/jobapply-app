    "axios": "^1.7.2",
    "dayjs": "^1.11.11",
    "i18next": "^26.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.1",
